            <svg class="w-6 h-6 text-cyan-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.12 6.85a2 2 0 0 0 0 3.66l9.05 4.67a2 2 0 0 0 1.66 0l9.05-4.67a2 2 0 0 0 0-3.66z"/><path d="m2.12 13.85 9.05 4.67a2 2 0 0 0 1.66 0l9.05-4.67"/><path d="m2.12 17.85 9.05 4.67a2 2 0 0 0 1.66 0l9.05-4.67"/></svg>
