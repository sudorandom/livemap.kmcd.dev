  <script is:inline>
    // Theme toggle
    const themeToggle = document.getElementById('theme-toggle');
    themeToggle?.addEventListener('click', () => {
      const element = document.documentElement;
      element.classList.toggle('dark');
      const isDark = element.classList.contains('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });

    // Gossip animation
    let gossipStep = 0;
    setInterval(() => {
      const paths = ['path-1', 'path-2', 'path-3', 'path-4', 'path-5', 'path-6'];
      if (gossipStep === 0) {
        document.getElementById('path-1').style.opacity = '1';
        document.getElementById('path-2').style.opacity = '1';
        gossipStep = 1;
      } else if (gossipStep === 1) {
        document.getElementById('path-3').style.opacity = '1';
        document.getElementById('path-4').style.opacity = '1';
        document.getElementById('path-5').style.opacity = '1';
        document.getElementById('path-6').style.opacity = '1';
        gossipStep = 2;
      } else {
        paths.forEach(id => {
          const el = document.getElementById(id);
          if (el) el.style.opacity = '0';
        });
        gossipStep = 0;
      }
    }, 2000);

    // Path animation
    let pathStep = 0;
    const paths = [
      "M40,40 L100,20 L160,40 L100,100 L160,160",
      "M40,40 L40,40 L100,100 L160,160",
      "M40,40 L40,160 L100,180 L160,160"
    ];
    setInterval(() => {
      const p = document.getElementById('animated-path');
      const n = document.getElementById('h-node-160-160');
      if (!p || !n) return;
      
      pathStep = (pathStep + 1) % paths.length;
      p.setAttribute('d', paths[pathStep]);
      n.style.opacity = '1';
    }, 3000);
  </script>
