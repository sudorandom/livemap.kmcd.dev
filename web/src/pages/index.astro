           >
             kmcd.dev &rarr;
           </a>
        </div>

        <div class="flex justify-center items-center gap-3">
          <div class="text-[11px] font-mono text-slate-500 uppercase tracking-[0.2em]">
            GLOBAL ROUTING TELEMETRY
          </div>
        </div>
