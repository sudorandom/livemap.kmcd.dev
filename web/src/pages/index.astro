                <style>
                  .shadow-glow-cyan { filter: drop-shadow(0 0 4px rgba(6, 182, 212, 0.5)); }
                  .shadow-glow-emerald { filter: drop-shadow(0 0 4px rgba(16, 185, 129, 0.5)); }
                  .dark .shadow-glow-cyan { filter: drop-shadow(0 0 8px rgba(34, 211, 238, 0.8)); }
                  .dark .shadow-glow-emerald { filter: drop-shadow(0 0 8px rgba(52, 211, 153, 0.8)); }
                  
                  #animated-path {
                    transition: d 1s ease-in-out;
                  }

                  @media (prefers-reduced-motion: reduce) {
                    #animated-path {
                      transition: none !important;
                    }
                    .animate-pulse {
                      animation: none !important;
                    }
                  }
                </style>

                <script>
                  function initPathAnimation() {
                    const container = document.getElementById('path-animation-container');
                    const path = document.getElementById('animated-path');
                    const allHighlightNodes = document.querySelectorAll('#path-nodes circle');
                    const playPauseBtn = document.getElementById('path-play-pause');
                    const playIcon = document.getElementById('play-icon');
                    const pauseIcon = document.getElementById('pause-icon');

                    if (!path) return;

                    const paths = [
                      {
                        d: "M40,40 L100,20 L160,40 L100,100 L160,160",
                        activeNodes: ['h-node-40-40', 'h-node-160-160']
                      },
                      {
                        d: "M40,40 L40,40 L100,100 L160,160 L160,160", 
                        activeNodes: ['h-node-40-40', 'h-node-160-160']
                      },
                      {
                        d: "M40,40 L40,160 L100,180 L160,160 L160,160",
                        activeNodes: ['h-node-40-40', 'h-node-160-160']
                      }
                    ];

                    let current = 0;
                    let isPlaying = true;
                    let intervalId: any = null;

                    function updateDisplay() {
                      allHighlightNodes.forEach(node => {
                        if (node.id !== 'h-node-40-40') {
                          (node as HTMLElement).style.opacity = '0';
                        }
                      });

                      const config = paths[current];
                      path.setAttribute('d', config.d);

                      setTimeout(() => {
                        const destNode = document.getElementById('h-node-160-160');
                        if (destNode) {
                          destNode.style.opacity = '1';
                        }
                      }, 1000);
                    }

                    function startCycle() {
                      stopCycle();
                      intervalId = setInterval(() => {
                        current = (current + 1) % paths.length;
                        updateDisplay();
                      }, 3500);
                      isPlaying = true;
                      playIcon?.classList.add('hidden');
                      pauseIcon?.classList.remove('hidden');
                    }

                    function stopCycle() {
                      if (intervalId) clearInterval(intervalId);
                      isPlaying = false;
                      playIcon?.classList.remove('hidden');
                      pauseIcon?.classList.add('hidden');
                    }

                    function togglePlayback(e?: Event) {
                      if (e) e.stopPropagation();
                      if (isPlaying) stopCycle();
                      else startCycle();
                    }

                    container?.addEventListener('click', () => togglePlayback());
                    playPauseBtn?.addEventListener('click', togglePlayback);

                    startCycle();
                  }

                  document.addEventListener('DOMContentLoaded', initPathAnimation);
                </script>
              </div>

              <div class="cyber-box p-6 rounded-xl bg-slate-50/50 dark:bg-slate-900/20 border-slate-200 dark:border-slate-800">
